# Text-to-SQL Data Q&A Agent — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Chat Provider (Required) ────────────────────────────────
# DeepSeek is the default. At least one chat provider key is required.
DEEPSEEK_API_KEY=sk-...

# ─── App Database (Required — Neon Serverless Postgres) ──────
# Stores auth + chat history. NOT the retail demo data.
# 1. Create a free account at https://console.neon.tech
# 2. Create a project and database
# 3. Copy the connection string (starts with postgresql://)
DATABASE_URL=postgresql://...

# ─── Retail Demo Database (Required — separate read-only DB) ──
# The retail_sales demo data the agent queries. MUST use a
# READ-ONLY role (retail_readonly) — see scripts/seed-retail-db.ts.
# The app runtime never has write access to this database.
RETAIL_DATABASE_URL=postgresql://retail_readonly:...

# Admin connection for seeding only (NOT used at runtime).
# Used by `npm run seed` to create tables + insert data + create
# the read-only role. Leave unset in production.
RETAIL_ADMIN_DATABASE_URL=postgresql://...

# ─── Authentication (Required) ───────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=your-secret-here
# Base URL of your app (used for redirects, cookies)
BETTER_AUTH_URL=http://localhost:3000

# ─── Development ─────────────────────────────────────────────
# Set to "true" to skip authentication locally
DEV_MODE=true
# Set to "true" to allow guest/demo access in production
ALLOW_GUEST=true

# ─── Other Providers (optional) ──────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
